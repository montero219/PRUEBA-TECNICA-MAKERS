POSTGRES_DB=atlas_pars
POSTGRES_USER=atlas_pars
POSTGRES_PASSWORD=CAMBIAR_LOCALMENTE
POSTGRES_PORT=5433

# Referencia futura para ejecucion containerizada de la API.
# El compose actual solo levanta PostgreSQL, por eso estas variables no se consumen
# en el flujo local del runbook. Para ejecutar la API localmente, configurar
# FirmaDecisiones:KeyId y FirmaDecisiones:ClaveActivaBase64 con dotnet user-secrets.
#
# La clave de firma HMAC-SHA256 de decisiones se genera con:
#   macOS/Linux:
#   CLAVE_FIRMA_BASE64="$(openssl rand -base64 32)"
#   printf '%s\n' "$CLAVE_FIRMA_BASE64"
#
#   Windows PowerShell:
#   $claveFirmaBase64 = [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#   $claveFirmaBase64
# Nunca commitear un valor real. En produccion esto vendria de Key Vault / Secrets Manager.
ATLAS_FIRMA_KEY_ID=atlas-pars-hmac-2026-07
ATLAS_FIRMA_CLAVE_BASE64=CAMBIAR_LOCALMENTE_BASE64_32_BYTES
