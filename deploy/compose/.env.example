POSTGRES_DB=atlas_pars
POSTGRES_USER=atlas_pars
POSTGRES_PASSWORD=CAMBIAR_LOCALMENTE
POSTGRES_PORT=5433

# Clave de firma HMAC-SHA256 de decisiones. Generar con:
#   openssl rand -base64 32
# o en PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# Nunca commitear un valor real. En produccion esto vendria de Key Vault / Secrets Manager.
ATLAS_FIRMA_KEY_ID=atlas-pars-hmac-2026-07
ATLAS_FIRMA_CLAVE_BASE64=CAMBIAR_LOCALMENTE_BASE64_32_BYTES
